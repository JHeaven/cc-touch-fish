{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "cc-touch-fish",
  "version": "0.1.2",
  "identifier": "com.cctouchfish.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "cc-touch-fish",
        "width": 135,
        "height": 175,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false
      },
      {
        "label": "bubble",
        "title": "Approval",
        "width": 380,
        "height": 329,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "visible": false,
        "url": "index.html"
      },
      {
        "label": "settings",
        "title": "CC Touch Fish",
        "width": 800,
        "height": 500,
        "resizable": false,
        "center": true,
        "decorations": true,
        "transparent": false,
        "visible": false,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ],
    "resources": [
      "D:\\WorkSpace\\cc-touch-fish\\public\\resources"
    ]
  }
}
